{
  // reuses every option from tsconfig.json, then only overrides what's
  // listed below.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true // this run only CHECKS types, it never writes .js files
  },
  // a separate, isolated project that includes the ONE deliberately-broken
  // file — kept out of tsconfig.json's own "include" list above so the
  // real, normal typecheck never sees it.
  "include": ["server.ts", "broken-usage.ts"]
}
