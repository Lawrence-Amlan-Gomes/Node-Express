# Real .env files (git-ignored by this project's root .gitignore) hold
# secrets and per-environment values — never commit a real one. This
# .env.example documents what's needed, with a placeholder value, so a
# teammate cloning the repo knows exactly what to put in their own .env.
#
# ?schema=node_express_learning tells Prisma which schema (a namespace of
# tables inside one database) to create the Task table in and query
# against — kept completely separate from any other tables that already
# live in this database's default "public" schema.
DATABASE_URL="postgres://user:password@host:5432/postgres?schema=node_express_learning"
