# Real .env files (git-ignored by this project's root .gitignore) hold
# secrets and per-environment values — never commit a real one.
#
# Its OWN dedicated schema, per the standing rule in build-conventions.md
# (every Prisma db push mini-project gets its own schema, never shared).
DATABASE_URL="postgres://user:password@host:5432/postgres?schema=node_express_learning_pagination"
