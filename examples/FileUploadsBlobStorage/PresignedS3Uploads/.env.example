# Real .env files (git-ignored by this project's root .gitignore) hold
# secrets and per-environment values — never commit a real one.
#
# This connects to a real, shared, self-hosted MinIO (S3-compatible) bucket
# — profile-photos — that ALREADY holds real objects from a different real
# project (a "products/" prefix). Every real object this example creates or
# deletes stays under its OWN dedicated prefix, "node-express-learning/" —
# never touches, lists, or deletes anything outside that prefix. Same
# isolation discipline as this project's dedicated Postgres schemas.
S3_ENDPOINT="https://your-minio-host"
S3_REGION="us-east-1"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_BUCKET="your-bucket"
S3_PUBLIC_URL="https://your-minio-host/your-bucket"
