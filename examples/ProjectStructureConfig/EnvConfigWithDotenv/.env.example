# Real .env files hold values that differ per environment (dev/staging/
# prod) or are secret (API keys, database URLs) — they should NEVER be
# committed to git. This .env.example file IS meant to be committed: it
# documents which variables the app needs, with placeholder/safe values,
# so a teammate cloning the repo knows exactly what their own real .env
# needs to contain. See this folder's real .env (git-ignored by this
# project's root .gitignore, which already has a "*.env" / "!.env.example"
# rule) for the actual values this demo runs with.
PORT=4032
GREETING_MESSAGE=replace-me-in-your-own-.env
