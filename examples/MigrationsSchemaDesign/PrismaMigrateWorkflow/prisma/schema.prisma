generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Step 2 of this topic's real migration history: the same Post table,
// now with a "published" column added. prisma/migrations/ has BOTH real,
// timestamped migrations — the first one that created this table with
// just a title, and the second one (below) that evolved it, generated
// by running "prisma migrate dev" again after adding this field here.
model Post {
  id        Int     @id @default(autoincrement())
  title     String
  published Boolean @default(false)
}
